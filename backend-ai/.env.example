# See app/core/config.py
# API_KEY_PLACEHOLDER=
# DEBUG=false
# LOG_LEVEL=INFO
# DATABASE_URL=sqlite:///./data/app.db
# JWT_SECRET=replace-with-long-random-secret-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
#
# CORS: comma-separated browser Origins (scheme+host+port only; no path).
# GitHub Pages https://<user>.github.io is also allowed by the API middleware (regex); add other origins here as needed.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Stub tailoring vs future LLM (see TAILORING_PROVIDER in config)
# TAILORING_PROVIDER=stub
# Optional; JobSpy passes this to scrapers; Indeed HTML fallback uses the same value (httpx).
# JOBSPY_PROXY=http://127.0.0.1:8888
# Indeed is off by default (403 from many IPs). Set true to include Indeed in JobSpy runs:
# JOBSPY_RUN_INDEED=true
# ZipRecruiter is off by default for the same reason:
# JOBSPY_RUN_ZIP_RECRUITER=true
#
# Indeed HTML fallback (direct SERP when JOBSPY_RUN_INDEED=true). Still needs a clean IP or JOBSPY_PROXY.
# INDEED_HTML_FALLBACK_ENABLED=false
# INDEED_HTML_MAX_LISTINGS=18
# INDEED_HTML_FROM_AGE_DAYS=14
#
# LinkedIn: guest HTML fetch runs when JobSpy returns no LinkedIn rows or marks LI unavailable.
# Set true to never use JobSpy for LinkedIn (only guest; avoids JOBSPY_PROXY for LI).
# LINKEDIN_GUEST_ENABLED=false
# LINKEDIN_USE_GUEST_INSTEAD_OF_JOBSPY=true
#
# Naukri listing discovery (HTML + optional Firecrawl; not via python-jobspy)
# FIRECRAWL_API_KEY=fc-...
# FireCrawl_API_KEY=fc-...   # alias
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_ENABLED=false    # optional: disable Firecrawl even if key set
# NAUKRI_HTML_ENABLED=false  # optional: disable Naukri HTML path
# NAUKRI_MAX_LISTINGS=18
# NAUKRI_HTTP_USER_AGENT=Mozilla/5.0 ...
